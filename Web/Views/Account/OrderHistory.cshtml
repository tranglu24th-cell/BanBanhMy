@using Core.Database.Models
@model IEnumerable<Order>
@{
    ViewData["Title"] = "Lịch sử mua hàng của bạn";
    Layout = "~/Views/Shared/_Site.cshtml";
}

<div class="container my-5" style="padding-top: 100px;">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-white py-3 border-0">
            <h4 class="mb-0 text-dark fw-bold">
                <i class="fas fa-history text-warning me-2"></i> Lịch Sử Mua Hàng Của Bạn
            </h4>
        </div>
        <div class="card-body p-4">
            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5">
                    <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" alt="No Order" style="width: 100px; opacity: 0.6;" />
                    <p class="text-muted fs-5 mt-3">Bạn chưa có đơn đặt hàng nào!</p>
                    <a href="/" class="btn btn-primary rounded-pill px-4 mt-2" style="background-color: #bfa37a; border-color: #bfa37a;">Mua hàng ngay</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Mã Đơn</th>
                                <th scope="col">Người Nhận</th>
                                <th scope="col">Số Điện Thoại</th>
                                <th scope="col">Địa Chỉ Giao</th>
                                <th scope="col" class="text-end">Trạng Thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-bold text-primary">#@item.Id.ToString().Substring(0, 8).ToUpper()</span>
                                    </td>
                                    <td>@(item.Customer != null ? item.Customer.Name : "Chưa cập nhật")</td>
                                    <td>@(item.Customer != null ? item.Customer.Phone : "Chưa cập nhật")</td>
                                    <td>@(item.Customer != null ? item.Customer.Address : "Chưa cập nhật")</td>
                                    <td class="text-end">
                                        @if (item.Status == OrderStatus.ChoDuyet)
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Chờ duyệt</span>
                                        }
                                        else if (item.Status == OrderStatus.DangLamBanh)
                                        {
                                            <span class="badge bg-info text-white rounded-pill px-3 py-2">Đang làm bánh</span>
                                        }
                                        else if (item.Status == OrderStatus.DangGiao)
                                        {
                                            <span class="badge bg-primary text-white rounded-pill px-3 py-2">Đang giao</span>
                                        }
                                        else if (item.Status == OrderStatus.DaHoanThanh)
                                        {
                                            <span class="badge bg-success text-white rounded-pill px-3 py-2">Đã hoàn thành</span>
                                        }
                                        else if (item.Status == OrderStatus.DaHuy)
                                        {
                                            <span class="badge bg-danger text-white rounded-pill px-3 py-2">Đã hủy</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary text-white rounded-pill px-3 py-2">Đã đặt hàng</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>