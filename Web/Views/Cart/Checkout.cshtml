@model List<Web.Models.CartItem>
@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    Layout = "~/Views/Shared/_Site.cshtml";
}

<div class="container-fluid bg-light py-3 mb-4 mt-0">
    <div class="container text-center animated bounceInDown">
        <h1 class="display-1 mb-4">Thanh Toán</h1>
    </div>
</div>

<div class="container py-5">
    <form action="/Cart/Checkout" method="post">
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-5">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="card-title mb-0"><i class="fas fa-user-edit mr-2"></i> Thông tin giao hàng</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" name="CustomerName" class="form-control" placeholder="Nhập họ và tên người nhận" required />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Số điện thoại <span class="text-danger">*</span></label>
                            <input type="tel" name="CustomerPhone" class="form-control" placeholder="Nhập số điện thoại giao hàng" required />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Địa chỉ nhận hàng <span class="text-danger">*</span></label>
                            <textarea name="CustomerAddress" class="form-control" rows="3" placeholder="Nhập địa chỉ cụ thể (Số nhà, tên đường...)" required></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-secondary text-white py-3">
                        <h5 class="card-title mb-0"><i class="fas fa-shopping-basket mr-2"></i> Đơn hàng của bạn</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (Model != null && Model.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-borderless align-middle mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="pl-4">Sản phẩm</th>
                                            <th class="text-center">Số lượng</th>
                                            <th class="text-right pr-4">Thành tiền</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model)
                                        {
                                            <tr class="border-bottom">
                                                <td class="pl-4 py-3">
                                                    <div class="d-flex align-items-center">
                                                        <img src="@item.Picture" style="width: 50px; height: 50px; object-fit: cover;" class="rounded mr-3" />
                                                        <div>
                                                            <h6 class="mb-0 font-weight-bold">@item.Title</h6>
                                                            <small class="text-muted">Đơn giá: @item.Price.ToString("#,##0") đ</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-center py-3 font-weight-bold">x @item.Amount</td>
                                                <td class="text-right pr-4 py-3 text-primary font-weight-bold">@item.Total.ToString("#,##0") đ</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="bg-light">
                                        <tr>
                                            <th colspan="2" class="pl-4 py-3 text-right">Tổng chi phí thanh toán:</th>
                                            <th class="text-right pr-4 py-3 text-danger h5 mb-0 font-weight-bold">@Model.Sum(i => i.Total).ToString("#,##0") đ</th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                    </div>
                </div>

                <div class="mt-4 text-right">
                    <a href="/Cart" class="btn btn-light rounded-pill py-2 px-4 mr-2">Quay lại giỏ hàng</a>
                    <button type="submit" class="btn btn-primary rounded-pill py-2 px-5 font-weight-bold shadow-sm">
                        <i class="fas fa-check-circle mr-2"></i>Xác nhận đặt hàng
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>