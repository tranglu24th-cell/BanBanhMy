@{
    ViewBag.Title = "Đặt lịch và tư vấn";
    Layout = "~/Views/Shared/_Site.cshtml";
}
<div class="container my-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-pill px-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-5">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 p-4 p-md-5" style="border-radius: 24px; background-color: #fff;">
                <h2 class="text-center text-primary mb-4" style="font-family: 'Playball', cursive; font-size: 3rem;">Phiếu Đăng Ký Đặt Lịch</h2>

                <form action="/Home/CreateBooking" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Status" value="Chờ duyệt" />
                    <input type="hidden" name="CreatedAt" value="@DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Họ và Tên</label>
                            <input type="text" name="FullName" class="form-control rounded-pill" placeholder="Nguyễn Văn A" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số Điện Thoại</label>
                            <input type="tel" name="Phone" class="form-control rounded-pill" placeholder="0901234567" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ngày Đến</label>
                            <input type="date" name="BookingDate" class="form-control rounded-pill" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Giờ Đến</label>
                            <input type="time" name="BookingTime" class="form-control rounded-pill" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Yêu Cầu Đặc Biệt</label>
                            <textarea name="Note" class="form-control" rows="3" style="border-radius: 15px;" placeholder="Ví dụ: Đặt bàn trà 2 người gần cửa sổ..."></textarea>
                        </div>
                        <div class="col-12 text-center mt-4">
                            <button type="submit" class="btn btn-primary rounded-pill py-3 px-5 text-white fw-bold shadow-sm" style="background-color: #B98B73; border: none;">Xác Nhận Đặt Chỗ</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 p-4" style="border-radius: 24px; background-color: #fff; max-height: 600px; overflow-y: auto;">
                <h4 class="fw-bold text-dark mb-4 text-center" style="font-family: 'Playball', cursive; font-size: 2.2rem; color: #B98B73 !important;">Lịch Đã Đăng Ký</h4>

                @if (ViewBag.ApprovedBookings != null)
                {
                    foreach (dynamic item in ViewBag.ApprovedBookings)
                    {
                        string borderClass = "border-warning";
                        string badgeClass = "bg-warning text-dark";
                        if (item.Status == "Đã xác nhận") { borderClass = "border-success"; badgeClass = "bg-success text-white"; }
                        else if (item.Status == "Từ chối") { borderClass = "border-danger"; badgeClass = "bg-danger text-white"; }

                        <div class="border-start border-4 @borderClass p-3 bg-light mb-3 rounded-end shadow-sm">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong class="text-dark">@item.FullName</strong>
                                <span class="badge @badgeClass rounded-pill px-2 py-1" style="font-size: 75%;">@item.Status</span>
                            </div>
                            <p class="small text-muted m-0 mt-1"><i class="far fa-clock me-1"></i> @item.BookingTime.ToString() - @item.BookingDate.ToString("dd/MM/yyyy")</p>
                            @if (!string.IsNullOrEmpty(item.Note))
                            {
                                <p class="small m-0 text-secondary mt-1"><em>"Yêu cầu: @item.Note"</em></p>
                            }
                            @if (!string.IsNullOrEmpty(item.AdminReply))
                            {
                                <div class="mt-2 p-2 bg-white rounded border small">
                                    <strong class="text-primary"><i class="fas fa-user-shield"></i> OldMil Phản hồi:</strong> @item.AdminReply
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>