@using Web.Models.EF
@{
    ViewBag.Title = "Trang chủ";
    Layout = "~/Views/Shared/_Site.cshtml";
}

<!-- Modal Search Start -->
<div class="modal fade" id="searchModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content rounded-0">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Search by keyword</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body d-flex align-items-center">
                <div class="input-group w-75 mx-auto d-flex">
                    <input type="search" class="form-control bg-transparent p-3" placeholder="keywords" aria-describedby="search-icon-1">
                    <span id="search-icon-1" class="input-group-text p-3"><i class="fa fa-search"></i></span>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Modal Search End -->
<!-- Hero Start -->
<div class="container-fluid hero-banner">

    <div class="hero-overlay"></div>

    <div class="container text-center">

        <div class="hero-content">

            <small class="bg-white text-dark px-4 py-2 rounded-pill">
                Tiệm bánh thủ công
            </small>


            <h1 class="display-3 mt-4">
                Những chiếc bánh
                ngọt ngào từ căn bếp nhỏ   
            </h1>


            <p class="text-muted mt-3">
                <b>
                    Bánh được làm mỗi ngày bằng sự tỉ mỉ
                    và những nguyên liệu chất lượng.
                </b>
            </p>


            <a href="@Url.Action("Index", "Product")"
               class="btn btn-primary px-5 py-3 mt-3">
                Xem bánh
            </a>


        </div>

    </div>

</div>
<!-- Hero End -->
<!-- About Satrt -->
<div class="container-fluid py-6" style="padding-top: 120px;">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5 wow bounceInUp" data-wow-delay="0.1s">
                <img src="/img/gthieu.jpg" class="img-fluid rounded shadow" alt="About Old Mill">
            </div>
            <div class="col-lg-7 wow bounceInUp" data-wow-delay="0.3s">
                <small class="d-inline-block fw-bold text-dark text-uppercase bg-light border border-primary rounded-pill px-4 py-1 mb-3" style="color: #bfa37a !important; border-color: #bfa37a !important;">
                    Giới thiệu
                </small>
                <h1 class="display-5 mb-4">Hơn 200+ khách hàng đã tin tưởng lựa chọn</h1>
                <p class="mb-4 text-muted">
                    Chào mừng bạn đến với Old Mill! Chúng tôi tự hào mang đến những chiếc bánh kem, bánh Choux Cream tươi ngon, làm thủ công ngay trong ngày với nguyên liệu cao cấp nhất. Sự hài lòng và niềm vui của bạn khi thưởng thức bánh chính là động lực lớn nhất của chúng tôi.
                </p>
                <div class="row g-4 text-dark mb-5">
                    <div class="col-sm-6">
                        <i class="fas fa-check text-primary me-2" style="color: #bfa37a;"></i>Bánh tươi làm mới mỗi ngày
                    </div>
                    <div class="col-sm-6">
                        <i class="fas fa-check text-primary me-2" style="color: #bfa37a;"></i>Giao hàng nhanh chóng tận nơi
                    </div>
                    <div class="col-sm-6">
                        <i class="fas fa-check text-primary me-2" style="color: #bfa37a;"></i>Hỗ trợ đặt bánh theo yêu cầu
                    </div>
                    <div class="col-sm-6">
                        <i class="fas fa-check text-primary me-2" style="color: #bfa37a;"></i>Nhiều ưu đãi đặc biệt hàng tuần
                    </div>
                </div>
                <a href="/Product" class="btn btn-primary py-3 px-5 rounded-pill" style="background-color: #bfa37a; border-color: #bfa37a;">
                    Xem sản phẩm <i class="fas fa-arrow-right ps-2"></i>
                </a>
            </div>
        </div>
    </div>
</div>
<!-- About End -->
<!-- Fact Start-->
<div class="container-fluid py-6" style="background-color: #ffffff;">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <div class="row g-4 justify-content-center">
                    <div class="col-sm-4 wow bounceInUp" data-wow-delay="0.3s">
                        <div class="p-4 text-center d-flex flex-column align-items-center justify-content-center"
                             style="background-color: #faf6f0; border: 1px solid #e1d3be; border-radius: 15px; min-height: 220px; height: 100%;">
                            <i class="fas fa-users fa-3x mb-3" style="color: #bfa37a;"></i>
                            <h1 class="display-5 fw-bold mb-2" style="color: #bfa37a; font-family: 'Playfair Display', serif;" data-toggle="counter-up">689</h1>
                            <p class="text-uppercase fw-bold mb-0" style="color: #8d775a; font-size: 13px; letter-spacing: 0.5px;">Khách Hàng Hài Lòng</p>
                        </div>
                    </div>
                    <div class="col-sm-4 wow bounceInUp" data-wow-delay="0.5s">
                        <div class="p-4 text-center d-flex flex-column align-items-center justify-content-center"
                             style="background-color: #faf6f0; border: 1px solid #e1d3be; border-radius: 15px; min-height: 220px; height: 100%;">
                            <i class="fas fa-users-cog fa-3x mb-3" style="color: #bfa37a;"></i>
                            <h1 class="display-5 fw-bold mb-2" style="color: #bfa37a; font-family: 'Playfair Display', serif;" data-toggle="counter-up">107</h1>
                            <p class="text-uppercase fw-bold mb-0" style="color: #8d775a; font-size: 13px; letter-spacing: 0.5px;">Thợ Bánh Chuyên Nghiệp</p>
                        </div>
                    </div>
                    <div class="col-sm-4 wow bounceInUp" data-wow-delay="0.7s">
                        <div class="p-4 text-center d-flex flex-column align-items-center justify-content-center"
                             style="background-color: #faf6f0; border: 1px solid #e1d3be; border-radius: 15px; min-height: 220px; height: 100%;">
                            <i class="fas fa-check fa-3x mb-3" style="color: #bfa37a;"></i>
                            <h1 class="display-5 fw-bold mb-2" style="color: #bfa37a; font-family: 'Playfair Display', serif;" data-toggle="counter-up">253</h1>
                            <p class="text-uppercase fw-bold mb-0" style="color: #8d775a; font-size: 13px; letter-spacing: 0.5px;">Đơn Hàng Hoàn Thành</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 wow bounceInUp" data-wow-delay="0.1s">
                <div class="position-relative overflow-hidden" style="border-radius: 15px; box-shadow: 0 8px 25px rgba(0,0,0,0.08);">
                    <img src="/img/banh.jpg" class="img-fluid w-100 d-block" alt="Tiệm bánh Old Mill" style="object-fit: cover; min-height: 220px;">
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Modal Video -->
<div class="modal fade" id="videoModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content rounded-0">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Youtube Video</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- 16:9 aspect ratio -->
                <div class="ratio ratio-16x9">
                    <iframe class="embed-responsive-item" src="" id="video" allowfullscreen allowscriptaccess="always"
                            allow="autoplay"></iframe>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Fact End -->
<!-- Service Start -->
<div class="container-fluid service py-6">
    <div class="container">

        <div class="text-center wow bounceInUp">
            <small class="d-inline-block fw-bold text-dark text-uppercase bg-light border border-primary rounded-pill px-4 py-1 mb-3">
                Về tiệm bánh
            </small>

            <h1 class="display-5 mb-5">
                Điều làm nên hương vị đặc biệt
            </h1>

        </div>


        <div class="row g-4">


            <div class="col-lg-3 col-md-6">
                <div class="service-item text-center">

                    <div class="service-content p-4">

                        <div class="service-content-icon">

                            <i class="fas fa-birthday-cake fa-5x text-primary mb-4"></i>

                            <h4 class="mb-3">
                                Bánh thủ công
                            </h4>

                            <p>
                                Mỗi chiếc bánh được làm bằng sự tỉ mỉ và yêu thương.
                            </p>

                        </div>

                    </div>

                </div>
            </div>



