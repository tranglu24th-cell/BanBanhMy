<div class="container-fluid blog py-6" style="background-color: #ffffff;">
    <div class="container">
        <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
            <small class="d-inline-block fw-bold text-uppercase bg-light border rounded-pill px-4 py-1 mb-3"
                   style="color: #bfa37a; border-color: #e1d3be !important; background-color: #faf6f0 !important;">
                Tin Tức & Góc Chia Sẻ
            </small>
            <h1 class="display-5 mb-5" style="font-family: 'Playfair Display', serif; color: #4a3f35;">Bài Viết Mới Nhất Từ Old Mill</h1>
        </div>

        <div class="row g-4">
            @if (ViewBag.LatestBlogs != null && ((List<Core.Database.Models.Article>)ViewBag.LatestBlogs).Count > 0)
            {
                foreach (var item in (List<Core.Database.Models.Article>)ViewBag.LatestBlogs)
                {
                    <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="blog-item shadow-sm rounded overflow-hidden" style="background-color: #faf6f0; border: 1px solid #e1d3be; transition: all 0.3s ease;">

                            <div class="blog-img position-relative overflow-hidden" style="height: 240px;">
                                <img class="img-fluid w-100 h-100" src="@item.Picture" alt="@item.Title" style="object-fit: cover; transition: transform 0.5s ease;">

                                <div class="blog-date text-white rounded-start d-flex flex-column justify-content-center text-center p-2"
                                     style="background-color: #bfa37a; position: absolute; bottom: 15px; left: 0; min-width: 70px;">
                                    @if (item.CreatedOn.HasValue)
                                    {
                                        <span class="fw-bold fs-5 mb-0">@item.CreatedOn.Value.ToString("dd")</span>
                                        <small class="fw-bold text-uppercase" style="font-size: 11px; opacity: 0.9;">Thg @item.CreatedOn.Value.Month</small>
                                    }
                                </div>
                            </div>

                            <div class="p-4 bg-white">
                                <a href="/Home/BlogDetail/@item.Id" class="text-decoration-none text-dark blog-title-link">
                                    <h5 class="fw-bold mb-3" style="font-family: 'Playfair Display', serif; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 48px;">
                                        @item.Title
                                    </h5>
                                </a>
                                <p class="text-muted" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; min-height: 72px; font-size: 14px;">
                                    @item.Description
                                </p>
                                <a class="text-uppercase fw-bold text-decoration-none" href="/Home/BlogDetail/@item.Id" style="color: #bfa37a; font-size: 13px;">
                                    Đọc tiếp <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted py-5">
                    <p class="mb-0">Hiện tại chưa có bài viết nào được chia sẻ.</p>
                </div>
            }
        </div>
    </div>
</div>
<div class="container mt-5">
    <h2 class="text-center mb-4 text-danger font-weight-bold" style="font-weight: 700;">🔥 BÁNH HOT THÁNG 7 🔥</h2>
    <div class="row">
        @if (ViewBag.BanhHotThang7 != null && ((List<Core.Database.Models.Product>)ViewBag.BanhHotThang7).Any())
        {
            foreach (var item in ViewBag.BanhHotThang7)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0 position-relative">
                        <span class="badge bg-danger position-absolute top-0 start-0 m-2 text-white">HOT</span>
                        <img src="~/images/@item.Picture" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover;" onerror="this.src='/images/default-cake.jpg'">
                        <div class="card-body text-center">
                            <h5 class="card-title font-weight-bold text-dark text-truncate">@item.Title</h5>
                            <p class="card-text text-danger font-weight-bold">@item.Price.ToString("#,##0") đ</p>
                            <a href="/Product/Detail/@item.Id" class="btn btn-outline-danger btn-sm w-100">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted"><p>Chưa có sản phẩm hot trong tháng này.</p></div>
        }
    </div>
</div>

<div class="container mt-5">
    <h2 class="text-center mb-4 text-warning font-weight-bold" style="font-weight: 700;">✨ BÁNH SẮP RA MẮT ✨</h2>
    <div class="row">
        @if (ViewBag.BanhSapRaMat != null && ((List<Core.Database.Models.Product>)ViewBag.BanhSapRaMat).Any())
        {
            foreach (var item in ViewBag.BanhSapRaMat)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0 opacity-75">
                        <img src="~/images/@item.Picture" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover; filter: grayscale(30%);" onerror="this.src='/images/default-cake.jpg'">
                        <div class="card-body text-center bg-light">
                            <h5 class="card-title text-muted text-truncate">@item.Title</h5>
                            <span class="badge bg-warning text-dark px-3 py-2">Coming Soon</span>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted"><p>Không có sản phẩm nào sắp ra mắt.</p></div>
        }
    </div>
</div>



<style>
    /* Hiệu ứng hover cho khối tin tức chuẩn chỉ */
    .blog-item:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 25px rgba(191, 163, 122, 0.25) !important;
        border-color: #bfa37a !important;
    }

        .blog-item:hover img {
            transform: scale(1.06);
        }

    .blog-title-link:hover h5 {
        color: #bfa37a !important;
    }
</style>
