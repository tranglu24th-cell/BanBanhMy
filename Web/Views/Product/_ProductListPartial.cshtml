@model IEnumerable<Core.Database.Models.Product>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col-md-4 col-sm-6 mb-4">
                <div class="card h-100 product-item-card">
                    <div class="position-relative">
                        <img src="@item.Picture" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover;">
                        @if (item.IsSale == true)
                        {
                            <span class="badge badge-danger position-absolute" style="top: 10px; left: 10px; background-color: red; color: white; padding: 5px 10px;">Gỉam giá</span>
                        }
                    </div>
                    <div class="card-body d-flex flex-column justify-content-between">
                        <h5 class="card-title font-weight-bold">@item.Title</h5>
                        <p class="card-text text-muted">@Html.Raw(item.Intro)</p>
                        <div class="mb-3">
                            @if (item.IsSale == true && item.PriceSale.HasValue)
                            {
                                <span class="text-danger font-weight-bold mr-2">@item.PriceSale.Value.ToString("#,##0") đ</span>
                                <span class="text-muted" style="text-decoration: line-through;">@item.Price.ToString("#,##0") đ</span>
                            }
                            else
                            {
                                <span class="text-dark font-weight-bold">@item.Price.ToString("#,##0") đ</span>
                            }
                        </div>
                        <button class="btn btn-primary btn-block btn-add-cart" data-id="@item.Id">
                            <i class="fas fa-shopping-cart mr-2"></i>Thêm vào giỏ
                        </button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center my-5">
            <p class="text-muted">Không tìm thấy sản phẩm nào phù hợp với bộ lọc.</p>
        </div>
    }
</div>

<div class="row">
    <div class="col-12 d-flex justify-content-center mt-4">
        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link btn-page" href="#" data-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>
<div class="col-md-9">
    <div id="product-list-container">
        <div class="text-center my-5 loading-spinner" style="display:none;">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Đang tìm bánh ngon cho bạn...</p>
        </div>

    </div>
</div>